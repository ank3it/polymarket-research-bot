# ---- Gordon (service broker + payments) ----
GORDON_PLATFORM_URL=https://api.withgordon.ai
GORDON_MCP_URL=https://api.withgordon.ai/mcp
GORDON_AGENT_API_KEY=gak_pub_xxx
GORDON_AGENT_API_SECRET=gak_sec_xxx

# ---- Polymarket (public read, no auth) ----
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com

# ---- Storage ----
DATABASE_PATH=research_bot.db

# ---- Catalog operations ----
# Enabled catalog (per Gordon dashboard): search = Exa, Tavily, Coingecko,
# Reversesandbox, Stableenrich, Twit; ai/LLM = Blockrun, Nansen, Ottoai;
# scrape = Zlurp; data = Oatp, Onesource, Zapper; infra = Seerium; finance = Stablefinance.
# Confirm exact operation_ids via `research-bot services "<query>"`.
# Exa is verified and works. Tavily is in the catalog but NOT probe-passed yet,
# so Gordon blocks it — default deep research to Exa too.
TRIAGE_SEARCH_OP=exa.search.web
DEEP_RESEARCH_OP=exa.search.web
# The enabled catalog currently has no general chat-completions service, so the
# probability estimate is a placeholder until you enable one (or wire a direct LLM).
INFERENCE_OP=blockrun.chat.completions
INFERENCE_MODEL=claude-3-5-sonnet-latest

# ---- Budget / routing (micro-units: 1_000_000 = $1.00) ----
TRIAGE_MAX_UNITS=10000          # $0.01 per triage search
DEEP_MAX_UNITS=10000            # keep per-call caps <= daily budget or calls get skipped
INFERENCE_MAX_UNITS=50000       # $0.05 per inference call
DAILY_BUDGET_UNITS=5000000      # $5.00 / day across all calls
ESTIMATOR_SAMPLES=5

# ---- Scan filters ----
MIN_LIQUIDITY=5000
MAX_DAYS_TO_RESOLUTION=120
MIN_DAYS_TO_RESOLUTION=2

# ---- Signal thresholds ----
EDGE_THRESHOLD=0.07
CONFIDENCE_THRESHOLD=0.6
